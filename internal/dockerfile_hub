FROM node:22-alpine AS web

WORKDIR /src/internal/site

COPY internal/site/package.json internal/site/package-lock.json ./
RUN npm ci

COPY internal/site ./
RUN npm run build

FROM golang:1.26-alpine AS builder

WORKDIR /src

RUN apk add --no-cache ca-certificates

COPY go.mod go.sum ./
RUN go mod download

COPY . ./
COPY --from=web /src/internal/site/dist ./internal/site/dist

RUN CGO_ENABLED=0 go build -ldflags "-w -s" -o /out/vigil ./internal/cmd/hub

FROM alpine:3.21

RUN apk add --no-cache ca-certificates

COPY --from=builder /out/vigil /app/vigil

VOLUME ["/vigil_data"]

EXPOSE 8090

ENTRYPOINT ["/app/vigil"]
CMD ["serve", "--http=0.0.0.0:8090"]
