FROM --platform=$BUILDPLATFORM golang:1.26-alpine AS builder

WORKDIR /src

RUN apk add --no-cache ca-certificates

COPY go.mod go.sum ./
RUN go mod download

COPY . ./

ARG TARGETOS
ARG TARGETARCH
ARG TARGETVARIANT
RUN set -eu; \
	GOARM=""; \
	if [ "$TARGETARCH" = "arm" ]; then GOARM="${TARGETVARIANT#v}"; fi; \
	CGO_ENABLED=0 GOOS="$TARGETOS" GOARCH="$TARGETARCH" GOARM="$GOARM" go build -ldflags "-w -s" -o /out/vigil ./internal/cmd/hub

FROM alpine:3.21

RUN apk add --no-cache ca-certificates

COPY --from=builder /out/vigil /app/vigil

VOLUME ["/vigil_data"]

EXPOSE 8090

ENTRYPOINT ["/app/vigil"]
CMD ["serve", "--http=0.0.0.0:8090"]
